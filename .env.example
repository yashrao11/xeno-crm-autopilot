# Xeno SmartReplenish AI - Environment Configuration

# Database Connection URL
# Fallback to local SQLite database if not specified: sqlite:///xeno_crm.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xeno_crm

# Optional: Groq API Key for AI Copilot (heuristic keyword parsing fallback will be used if invalid/empty)
# GROQ_API_KEY=your_groq_api_key_here

# Optional: Decoupled service endpoint URLs for external/deployed servers
# CRM_CALLBACK_URL=https://your-crm-app.onrender.com/api/webhooks/receipt
# CHANNEL_SERVICE_URL=https://your-channel-stub-app.onrender.com/channel/send
